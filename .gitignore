# secrets — never commit
.env
.env.local
.env.*.local
**/.env
**/.env.local

# dependencies / build
node_modules/
**/node_modules/
.expo/
**/.expo/
dist/
web-build/

# logs + scratch
*.log
data/sourcing/_*.log
data/acquisition/raw/*.json

# derived / runtime data + regenerated reports.
# The flat topic pool + harvest cursor ARE committed — they're the cloud harvester's
# persistent, accumulating state (the drafter reads pool.json). The vestigial
# per-category stores and the append-only run log stay local-only.
data/sourcing/topics/*
!data/sourcing/topics/pool.json
data/sourcing/harvest-log.jsonl
data/acquisition/feedback-issue-audit.*
data/acquisition/source-verification-*
data/acquisition/clue-critique-*
data/acquisition/grader-override-mining.*
data/acquisition/clue-edits.*

# os
.DS_Store
Thumbs.db
