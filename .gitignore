# derived / runtime data + regenerated reports — local-only, never commit.
# These change on every daily harvest/audit run; committing them makes every
# unreviewed daily PR collide on the same files. Tools read them from local disk.
data/sourcing/topics/
data/sourcing/harvest-state.json
data/sourcing/harvest-log.jsonl
data/acquisition/feedback-issue-audit.*
data/acquisition/source-verification-*
data/acquisition/grader-override-mining.*
data/acquisition/clue-edits.*

# os
.DS_Store
Thumbs.db
